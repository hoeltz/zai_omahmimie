{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "build": {
    "env": {
      "PRISMA_GENERATE_DATAPROXY": "false"
    }
  },
  "functions": {
    "src/app/api/properties/[id]/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/properties/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/upload/route.ts": {
      "maxDuration": 30
    }
  }
}